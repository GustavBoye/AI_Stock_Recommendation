# ─────────────────────────────────────────────
# HELPERS
# ─────────────────────────────────────────────
def normalize_min_max(data):
    dmin = np.min(data, axis=0)
    dmax = np.max(data, axis=0)
    denom = dmax - dmin
    denom[denom == 0] = 1e-8
    return (data - dmin) / denom


def create_input(data, vol, high, low, time_steps):
    a = normalize_min_max(data[-time_steps:])
    b = normalize_min_max(vol[-time_steps:])
    c = normalize_min_max(high[-time_steps:])
    d = normalize_min_max(low[-time_steps:])
    inp = np.concatenate([a, b, c, d], axis=1)
    return np.array([inp])   # shape (1, time_steps, features)


def create_dataset(data, vol, high, low, time_steps, future_steps, inverted=False):
    if inverted:
        data = 1 - data
        high = 1 - high
        low  = 1 - low

    X, y = [], []
    for i in range(len(data) - time_steps - future_steps):
        a = normalize_min_max(data[i:i + time_steps])
        b = normalize_min_max(vol[i:i + time_steps])
        c = normalize_min_max(high[i:i + time_steps])
        d = normalize_min_max(low[i:i + time_steps])
        X.append(np.concatenate([a, b, c, d], axis=1))

        future_prices     = data[i + time_steps: i + time_steps + future_steps]
        current_price     = data[i + time_steps - 1]
        future_avg        = np.mean(future_prices, axis=0)
        y.append(future_avg - current_price)

    return np.array(X), np.array(y)


def build_model(shape1, shape2, n_tickers):
    inp = tf.keras.layers.Input(shape=(shape1, shape2))
    x   = tf.keras.layers.SpatialDropout1D(random.uniform(0.5, 0.9))(inp)
    x   = tf.keras.layers.Dropout(random.uniform(0.1, 0.7))(x)

    for _ in range(random.randint(2, 4)):
        x = tf.keras.layers.SeparableConv1D(
            filters=shape2, kernel_size=3, strides=2,
            padding="same", depth_multiplier=1
        )(x)
        x = tf.keras.layers.LayerNormalization()(x)
        x = tf.keras.layers.Activation("gelu")(x)

    x = tf.keras.layers.Flatten()(x)
    x = tf.keras.layers.Dropout(random.uniform(0.2, 0.85))(x)
    x = tf.keras.layers.Dense(random.randint(16, 64), activation="gelu")(x)
    x = tf.keras.layers.LayerNormalization()(x)
    x = tf.keras.layers.Dropout(random.uniform(0.2, 0.7))(x)
    x = tf.keras.layers.Dense(random.randint(8, 64), activation="gelu")(x)

    if random.randint(0, 1):
        if random.randint(0, 1):
            x = tf.keras.layers.LayerNormalization()(x)
        x = tf.keras.layers.Dense(random.randint(8, 64), activation="gelu")(x)

    out   = tf.keras.layers.Dense(n_tickers)(x)
    model = tf.keras.Model(inp, out)
    return model


# ─────────────────────────────────────────────
# MULTI-HORIZON TRAINING
# ─────────────────────────────────────────────
HORIZONS    = [32, 64, 76, 90, 120]
NUM_MODELS  = 2   # ensemble size per horizon
N_TICKERS   = len(input_tickers)

early_stopping = EarlyStopping(
    monitor='val_loss', patience=32, min_delta=1e-4,
    restore_best_weights=True, mode='min', verbose=1
)
lr_scheduler = tf.keras.callbacks.ReduceLROnPlateau(
    monitor='val_loss', factor=0.5, patience=10, verbose=1
)

# horizon → { ticker: predicted_change }
all_predictions = {}

for horizon in HORIZONS:
    DAYS    = horizon
    HISTORY = horizon
    print(f"\n{'='*60}")
    print(f"  HORIZON: {DAYS} days  (history={HISTORY})")
    print(f"{'='*60}")

    X, y         = create_dataset(data_scaled, data_scaled_vol, data_scaled_high, data_scaled_low, HISTORY, DAYS)
    X_inv, y_inv = create_dataset(data_scaled, data_scaled_vol, data_scaled_high, data_scaled_low, HISTORY, DAYS, inverted=True)

    X_comb = np.concatenate([X, X_inv], axis=0)
    y_comb = np.concatenate([y, y_inv], axis=0)

    inp_data = create_input(data_scaled, data_scaled_vol, data_scaled_high, data_scaled_low, HISTORY)

    ensemble = []
    for i in range(NUM_MODELS):
        print(f"  → Model {i+1}/{NUM_MODELS}")
        model = build_model(X_comb.shape[1], X_comb.shape[2], N_TICKERS)
        model.compile(optimizer=tf.keras.optimizers.AdamW(1e-3), loss='mse')
        model.fit(
            X_comb, y_comb,
            epochs=4, batch_size=6,
            validation_split=0.35,
            verbose=1,
            callbacks=[early_stopping, lr_scheduler]
        )
        ensemble.append(model)

    # Average ensemble predictions
    preds = {}
    for idx, ticker in enumerate(input_tickers):
        preds[ticker] = float(np.mean([m(inp_data).numpy()[0, idx] for m in ensemble]))

    all_predictions[horizon] = preds
    print(f"  ✓ Horizon {DAYS}d complete")


