def horizon_color(i, n):
    """Interpolate red→yellow→green."""
    ratio = i / max(n - 1, 1)
    if ratio < 0.5:
        r = 1.0
        g = ratio * 2 * 0.85
        b = 0.1
    else:
        r = (1 - ratio) * 2 * 0.85
        g = 0.85
        b = 0.1
    return (r, g, b)

